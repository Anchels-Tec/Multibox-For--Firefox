{
  "manifest_version": 3,
  "name": "Multibox",
  "version": "1.0.1",
  "description": "Abra varias sessoes isoladas do mesmo site (ex: 2 WhatsApp, 2 Instagram) no mesmo Firefox, usando caixas (containers) com login separado.",
  "browser_specific_settings": {
    "gecko": {
      "id": "multibox@ailan",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "icons": { "48": "icons/box.svg", "96": "icons/box.svg" },
  "permissions": ["contextualIdentities", "cookies", "tabs", "storage", "menus"],
  "background": { "scripts": ["background.js"] },
  "action": {
    "default_title": "Multibox",
    "default_popup": "popup.html",
    "default_icon": { "48": "icons/box.svg" }
  }
}
